{
  "name": "fixturemint",
  "version": "0.1.0",
  "description": "Deterministic fixture pack generator for JSON Schema and local recipes.",
  "type": "module",
  "bin": {
    "fixturemint": "./dist/src/cli.js"
  },
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    }
  },
  "files": [
    "dist/src",
    "examples",
    "README.md",
    "LICENSE",
    "SECURITY.md",
    "CHANGELOG.md",
    "CONTRIBUTING.md",
    "CODE_OF_CONDUCT.md"
  ],
  "scripts": {
    "build": "tsc",
    "check": "tsc --noEmit",
    "test": "npm run build && node --test \"dist/**/*.test.js\"",
    "smoke": "npm run build && node dist/src/cli.js generate examples/user.schema.json --recipe examples/user.recipe.yaml --seed 42 --out fixtures/smoke && node dist/src/cli.js manifest fixtures/smoke --out fixtures/smoke-manifest.json",
    "package:smoke": "npm pack --dry-run",
    "release:check": "npm run check && npm test && npm run smoke && npm run package:smoke"
  },
  "keywords": [
    "fixtures",
    "json-schema",
    "testing",
    "cli",
    "deterministic"
  ],
  "author": "Roger Chappel",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "yaml": "^2.7.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "typescript": "^5.7.2"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rogerchappel/fixturemint.git"
  },
  "bugs": {
    "url": "https://github.com/rogerchappel/fixturemint/issues"
  },
  "homepage": "https://github.com/rogerchappel/fixturemint#readme"
}
